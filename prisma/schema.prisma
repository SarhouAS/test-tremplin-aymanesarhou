generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Civilite {
  M
  MME
}

enum TypeDemande {
  VISITE
  RAPPEL
  PHOTOS
}

model Contact {
  id             Int             @id @default(autoincrement())
  civilite       Civilite
  nom            String
  prenom         String
  email          String
  telephone      String
  typeDemande    TypeDemande
  message        String          @db.Text
  disponibilites Disponibilite[]
  createdAt      DateTime        @default(now())
}

model Disponibilite {
  id        Int     @id @default(autoincrement())
  jour      String  // ex: "Lundi"
  heure     Int     // ex: 7
  minute    Int     // ex: 45
  contact   Contact @relation(fields: [contactId], references: [id])
  contactId Int
}